# 배포용 환경변수 예시 — 실제 값은 서버에서 deploy/.env 로 복사해 채운다.
# ⚠️ 실제 키가 담긴 .env 는 절대 커밋/전송 로그에 노출하지 말 것.

# 데이터 모드 (mock 데모 = true 유지 권장)
USE_MOCK_DATA=true

# 실제 Postgres 연동 전환 시에만 (mock 모드면 무시됨)
# DATABASE_URL=postgresql+asyncpg://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:5432/oceantensor_db

# XAI LLM 라이브 (선택) — 없으면 템플릿 폴백으로 동작
# GEMINI_API_KEY=
