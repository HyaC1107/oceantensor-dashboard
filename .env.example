# DB
DATABASE_URL=postgresql+asyncpg://oceantensor_user:<DB_PASSWORD>@localhost:5432/oceantensor_db

# 공공API 키 (data.go.kr 발급)
KOEM_API_KEY=your_koem_key_here
NIFS_API_KEY=your_nifs_key_here
KMA_API_KEY=your_kma_key_here

# Mock 모드 (API 키 없을 때 true로 설정)
USE_MOCK_DATA=true

# LLM (RAG용)
ANTHROPIC_API_KEY=your_anthropic_key_here
